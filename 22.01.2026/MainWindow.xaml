<Window x:Class="_22._01._2026.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_22._01._2026"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="10">
            <TextBlock Text="поле 1" Margin="0,0,0,5"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBox Name="T1_1" Width="30" BorderThickness="0,0,0,1" BorderBrush="Black" TextAlignment="Center" Margin="2"/>
                <TextBox Name="T1_2" Width="30" BorderThickness="0,0,0,1" BorderBrush="Black" TextAlignment="Center" Margin="2"/>
                <TextBox Name="T1_3" Width="30" BorderThickness="0,0,0,1" BorderBrush="Black" TextAlignment="Center" Margin="2"/>
                <TextBox Name="T1_4" Width="30" BorderThickness="0,0,0,1" BorderBrush="Black" TextAlignment="Center" Margin="2"/>
            </StackPanel>

            <TextBlock Text="поле 2" Margin="0,0,0,5"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBox Name="T2_1" Width="30" BorderThickness="0" TextAlignment="Center" Margin="2" TextChanged="T2_TextChanged"/>
                <TextBox Name="T2_2" Width="30" BorderThickness="0" TextAlignment="Center" Margin="2" TextChanged="T2_TextChanged"/>
                <TextBox Name="T2_3" Width="30" BorderThickness="0" TextAlignment="Center" Margin="2" TextChanged="T2_TextChanged"/>
                <TextBox Name="T2_4" Width="30" BorderThickness="0" TextAlignment="Center" Margin="2" TextChanged="T2_TextChanged"/>
            </StackPanel>

            <TextBlock Text="поле 3" Margin="0,0,0,5"/>
            <TextBox Name="T3_Main" Margin="0,0,0,20" LostFocus="T3_Main_LostFocus" KeyDown="T3_Main_KeyDown"/>

            <TextBlock Text="поле 4" Margin="0,0,0,5"/>
            <StackPanel Orientation="Horizontal">
                <TextBox Name="T4_1" Width="30" BorderThickness="0,0,0,1" BorderBrush="Black"/>
                <TextBlock Text="." VerticalAlignment="Bottom"/>
                <TextBox Name="T4_2" Width="30" BorderThickness="0,0,0,1" BorderBrush="Black"/>
                <TextBlock Text="." VerticalAlignment="Bottom"/>
                <TextBox Name="T4_3" Width="30" BorderThickness="0,0,0,1" BorderBrush="Black"/>
                <TextBlock Text="." VerticalAlignment="Bottom"/>
                <TextBox Name="T4_4" Width="30" BorderThickness="0,0,0,1" BorderBrush="Black"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Column="1" Margin="10">
            <TextBlock Text="перевод"/>
            <TextBox Name="EngInput" Margin="0,5" TextChanged="EngInput_TextChanged"/>
            <TextBox Name="RusOutput" Margin="0,5" IsEnabled="False"/>
        </StackPanel>

        <Canvas Grid.Column="2" Name="ImageCanvas">
            <TextBlock Canvas.Top="10" Canvas.Left="10" Text="двойной клик"/>

            <Image Name="Pic1" Width="100" Height="100" Canvas.Top="50" Canvas.Left="30" 
           MouseLeftButtonDown="Pic1_MouseLeftButtonDown" Stretch="UniformToFill"/>

            <Image Name="Pic2" Width="100" Height="100" Canvas.Top="170" Canvas.Left="30" 
           Stretch="UniformToFill"/>
        </Canvas>

        <StackPanel Grid.Column="3" Margin="10">
            <TextBlock Text="списки"/>
            <ComboBox Name="Combo1" Margin="0,5" SelectionChanged="Combo1_SelectionChanged">
                <ComboBoxItem Content=""/>
                <ComboBoxItem Content="1"/>
                <ComboBoxItem Content="2"/>
            </ComboBox>
            <ComboBox Name="Combo2" Margin="0,5">
                <ComboBoxItem Content=""/>
                <ComboBoxItem Content="4"/>
                <ComboBoxItem Content="5"/>
            </ComboBox>
            <ComboBox Name="Combo3" Margin="0,5">
                <ComboBoxItem Content=""/>
                <ComboBoxItem Content="7"/>
                <ComboBoxItem Content="8"/>
            </ComboBox>
        </StackPanel>
    </Grid>
</Window>
