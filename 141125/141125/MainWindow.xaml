<Window x:Class="_141125.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_141125"
        mc:Ignorable="d"
        Title="MainWindow" Height="250" Width="500">
    <StackPanel Margin="15">

        <TextBlock Text="Размер массива от 1 до 20:" Margin="0,0,0,5"/>
        <TextBox x:Name="TextBoxSize"
                 MaxLength="2"
                 PreviewTextInput="One"
                 Margin="0,0,0,15"/>

        <TextBlock Text="Элементы массива числа через ; :" Margin="0,0,0,5"/>
        <TextBox x:Name="TextBoxElements"
                 PreviewTextInput="Two" 
                 Margin="0,0,0,25"/>

        <Button Content="Записать" Click="Button_Click" Padding="5" Width="155"/>

    </StackPanel>
</Window>
