<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MainWindow" Height="400" Width="500">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,20,0,0">

            <Button Content="Массивы" Width="250" Height="60" Margin="0,10,0,0"
                    Click="Arrays_Click" Background="White" BorderBrush="Black" 
                    BorderThickness="2" FontSize="18"  >
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="15"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button Content="Строки" Width="250" Height="60" Margin="0,10,0,0"
                    Click="Strings_Click" Background="White" BorderBrush="Black" BorderThickness="2" FontSize="18">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="15"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button Content="Перевод" Width="250" Height="60" Margin="0,10,0,0"
                    Click="Translate_Click" Background="White" BorderBrush="Black" BorderThickness="2" FontSize="18">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="15"/>
                    </Style>
                </Button.Resources>
            </Button>

        </StackPanel>
    </Grid>
</Window>
