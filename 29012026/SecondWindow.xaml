<Window x:Class="_29012029.SecondWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_29012029"
        mc:Ignorable="d"
        Title="Элементы" Height="600" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
            <ComboBox x:Name="ElementSelector" Width="100" SelectionChanged="ElementSelector_SelectionChanged">
                <ComboBoxItem Content="1"/>
                <ComboBoxItem Content="2"/>
                <ComboBoxItem Content="3"/>
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="1">

            <GroupBox Header="Эл 1" x:Name="Group1" 
          Visibility="Collapsed" 
          d:Visibility="Visible" 
          Margin="0,0,0,15" BorderBrush="White" FontSize="18">
                <StackPanel>
                    <TextBox x:Name="CalcInput" LostFocus="CalcInput_LostFocus" PreviewTextInput="CalcInput_PreviewTextInput" Width="757" Height="47" KeyDown="CalcInput_Enter" FontSize="20"/>
                    <TextBlock x:Name="CalcResult" FontWeight="Bold" Margin="5"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Эл 2" x:Name="Group2" 
          Visibility="Collapsed" 
          d:Visibility="Visible" 
          Margin="0,0,0,15" BorderBrush="White" FontSize="18">
                <Button Content="Button" Height="28" Click="Open_Click" Margin="0,0,670,0"/>
            </GroupBox>

            <GroupBox Header="Эл 3" x:Name="Group3" 
          Visibility="Collapsed"
          d:Visibility="Visible" BorderBrush="White" FontSize="18">
                
             <TextBox x:Name="TextInput" 
             Height="265" 
             TextWrapping="Wrap" 
             AcceptsReturn="True"
             TextChanged="TextInput_TextChanged"  FontSize="18"/>
            </GroupBox>

        </StackPanel>
    </Grid>
</Window>
