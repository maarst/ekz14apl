<Window x:Class="_29012029.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_29012029"
        mc:Ignorable="d"
        Title="Авторизация" Height="450" Width="800" WindowStartupLocation="CenterScreen">
    <StackPanel Margin="20" VerticalAlignment="Center">
        <TextBlock Text="логин:" Width="369" FontSize="24"/>
        <TextBox x:Name="LoginBox" 
                 Margin="0,5,0,10"
                 PreviewTextInput="LoginBox_CheckText"
                 PreviewKeyDown="LoginBox_CheckSpace" Height="34" Width="370" FontSize="20"/>

        <TextBlock Text="пароль:" Width="370" FontSize="24"/>
        <PasswordBox x:Name="PassBox" Margin="0,5,0,20" Width="370" Height="32" FontSize="20"/>

        <Button Content="войти" Click="Button_Click" Height="38" Width="112" FontSize="24"/>
    </StackPanel>
</Window>
