<Window x:Class="WPF21.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF21"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Массив A:" 
                   Margin="0,0,0,5" FontWeight="Bold"/>
        <TextBox Grid.Row="2" Grid.Column="0" Name="txtArrayA" Height="50" 
                 TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                 Text="" Margin="0,0,10,15"
                 FontSize="12" Padding="5" Foreground="Black"/>

        <TextBlock Grid.Row="1" Grid.Column="1" Text="Массив B:" 
                   Margin="0,0,0,5" FontWeight="Bold"/>
        <TextBox Grid.Row="2" Grid.Column="1" Name="txtArrayB" Height="50" 
                 TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                 Text="" Margin="10,0,0,15"
                 FontSize="12" Padding="5" Foreground="Black"/>

        <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" 
                    Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
            <Button Name="btnAdd" Content="+" Width="40" Height="35" 
                    Margin="5" Click="Operation_Click" FontWeight="Bold" FontSize="16"/>
            <Button Name="btnSubtract" Content="-" Width="40" Height="35" 
                    Margin="5" Click="Operation_Click" FontWeight="Bold" FontSize="16"/>
            <Button Name="btnMultiply" Content="*" Width="40" Height="35" 
                    Margin="5" Click="Operation_Click" FontWeight="Bold" FontSize="16"/>
            <Button Name="btnDivide" Content="/" Width="40" Height="35" 
                    Margin="5" Click="Operation_Click" FontWeight="Bold" FontSize="16"/>
            <Button Name="btnSave" Content="Сохранить" Width="100" Height="35" 
                    Margin="20,5,5,5" Click="BtnSave_Click" FontWeight="Bold" IsEnabled="False" BorderBrush="Black" Foreground="Black"/>
        </StackPanel>

        <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" 
                   Text="Результат:" 
                   Margin="0,20,0,5" FontWeight="Bold" FontSize="14"/>
        <TextBox Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Name="txtResult" 
                 Height="150" IsReadOnly="True" TextWrapping="Wrap" 
                 VerticalScrollBarVisibility="Auto" Margin="0,0,0,10"
                 FontSize="12" FontFamily="Consolas" Padding="10"
                 VerticalContentAlignment="Top" HorizontalContentAlignment="Left"/>
    </Grid>

</Window>
