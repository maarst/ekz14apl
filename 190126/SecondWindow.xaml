<Window x:Class="_190126.SecondWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_190126"
        mc:Ignorable="d"
        Title="SecondWindow" Height="450" Width="450">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <ComboBox HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,35,0,0" Width="150">
            <ComboBoxItem Content="Значение 1" IsSelected="True"/>
            <ComboBoxItem Content="Значение 2"/>
            <ComboBoxItem Content="Значение 3"/>
        </ComboBox>

        <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10">
            <DatePicker x:Name="AutoDatePicker" Width="150" Margin="0,0,0,5"/>
            <TextBox x:Name="ManualDateBox" Width="150" PreviewTextInput="ManualDateBox_PreviewTextInput" MaxLength="10" Text="00.00.0000"/>
        </StackPanel>

        <Button Content="Сохранить" Grid.Row="1" HorizontalAlignment="Left" 
                VerticalAlignment="Bottom" Margin="35,0,0,103" Width="100" Click="Save_Click"/>

        <TextBox x:Name="NoteTextBox" Grid.Column="1" 
                 HorizontalAlignment="Center" VerticalAlignment="Center" Width="200" Height="186" TextWrapping="Wrap" Grid.Row="1"/>
    </Grid>
</Window>
