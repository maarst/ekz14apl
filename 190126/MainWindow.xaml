<Window x:Class="_190126.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_190126"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="450">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Button Content="Button" HorizontalAlignment="Left" VerticalAlignment="Top" 
                Margin="20" Width="75" Height="30" Click="ShowMessage_Click"/>

        <TextBox x:Name="EnglishTextBox" Grid.Column="1" HorizontalAlignment="Right" 
                 VerticalAlignment="Top" Width="167" Height="56" Margin="0,20,20,0" 
                 PreviewTextInput="EnglishTextBox_PreviewTextInput" />

        <StackPanel Grid.Row="1" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="20">
            <CheckBox x:Name="Эл1" Content="Элемент 1" Margin="0,5" Click="CheckBox_Click"/>
            <CheckBox x:Name="Эл2" Content="Элемент 2" Margin="0,5" Click="CheckBox_Click"/>
            <CheckBox x:Name="Эл3" Content="Элемент 3" Margin="0,5" Click="CheckBox_Click"/>
        </StackPanel>

        <Image x:Name="ToggleImage" Grid.Row="1" Grid.Column="1" Width="150" Height="150"
               HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="10"
               Source="image1.png" MouseLeftButtonDown="ToggleImage_MouseDown" Cursor="Hand"/>
    </Grid>
</Window>
